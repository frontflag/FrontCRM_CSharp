{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=FrontCRM;Username=postgres;Password=adm@FF#1720"
  },
  "DocumentModule": {
    "RootPath": "Uploads",
    "MaxFileSizeMb": 50,
    "MaxFilesPerUpload": 5,
    "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png", ".docx", ".xlsx", ".zip" ],
    "Thumbnail": {
      "Enable": true,
      "MaxWidth": 400,
      "MaxHeight": 400,
      "Quality": 80
    }
  },
  "Wechat": {
    "AppId": "wx_your_app_id_here",
    "AppSecret": "your_app_secret_here",
    "CallbackDomain": "http://129.226.161.3",
    "QrCodeExpireSeconds": 300
  },
  "Jwt": {
    "SecretKey": "your-secret-key-here-min-32-characters",
    "Issuer": "FrontCRM",
    "Audience": "FrontCRM-Users",
    "ExpirationMinutes": 480
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Error",
        "Microsoft.EntityFrameworkCore": "Error",
        "System": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}",
          "retainedFileCountLimit": 7
        }
      }
    ]
  }
}
